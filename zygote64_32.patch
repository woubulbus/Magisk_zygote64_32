From e16ae7d09dbfd57c21ccae7c5e0f9e67040c8457 Mon Sep 17 00:00:00 2001
From: GitHub Actions <actions@github.com>
Date: Fri, 24 Apr 2026 14:00:33 +0000
Subject: [PATCH] zygote64_32

---
 native/src/init/rootdir.cpp | 46 +++++++++++++++++++++++++++++++++++++
 1 file changed, 46 insertions(+)

diff --git a/native/src/init/rootdir.cpp b/native/src/init/rootdir.cpp
index c3d1f02..e38905b 100644
--- a/native/src/init/rootdir.cpp
+++ b/native/src/init/rootdir.cpp
@@ -14,6 +14,8 @@ static vector<string> rc_list;
 
 #define NEW_INITRC_DIR  "/system/etc/init/hw"
 #define INIT_RC         "init.rc"
+#define VENDOR_DIR      "/vendor"
+#define BUILD_PROP      "build.prop"
 
 static bool unxz(int fd, rust::Slice<const uint8_t> bytes) {
     uint8_t out[8192];
@@ -136,6 +138,45 @@ static bool patch_rc_scripts(const char *src_path, const char *tmp_path, bool wr
     return faccessat(src_fd, "init.fission_host.rc", F_OK, 0) == 0;
 }
 
+static void patch_build_prop(const char *src_path) {
+    auto src_dir = xopen_dir(src_path);
+    if (!src_dir) return;
+    int src_fd = dirfd(src_dir.get());
+
+    auto dest_dir = [&] {
+        char buf[PATH_MAX] = {};
+        ssprintf(buf, sizeof(buf), ROOTOVL "%s", src_path);
+        xmkdirs(buf, 0755);
+        return xopen_dir(buf);
+    }();
+    if (!dest_dir) return;
+    int dest_fd = dirfd(dest_dir.get());
+
+    owned_fd src_bp = xopenat(src_fd, BUILD_PROP, O_RDONLY | O_CLOEXEC, 0);
+    if (src_bp < 0) return;
+    auto dest_bp = xopen_file(
+            xopenat(dest_fd, BUILD_PROP, O_WRONLY | O_CREAT | O_TRUNC | O_CLOEXEC, 0), "we");
+    if (!dest_bp) return;
+    LOGD("Patching " BUILD_PROP " in %s\n", src_path);
+    file_readline(src_bp, [&dest_bp](Utf8CStr line) -> bool {
+        if (line.sv().starts_with("ro.zygote=zygote64")) {
+            fprintf(dest_bp.get(), "ro.zygote=zygote64_32\n");
+            return true;
+        }
+        if (line.sv().starts_with("ro.vendor.product.cpu.abilist=arm64-v8a")) {
+            fprintf(dest_bp.get(), "ro.vendor.product.cpu.abilist=arm64-v8a,armeabi-v7a,armeabi\n");
+            return true;
+        }
+        if (line.sv().starts_with("ro.vendor.product.cpu.abilist32=")) {
+            fprintf(dest_bp.get(), "ro.vendor.product.cpu.abilist32=armeabi-v7a,armeabi\n");
+            return true;
+        }
+        fprintf(dest_bp.get(), "%s", line.c_str());
+        return true;
+    });
+    fclone_attr(src_bp, fileno(dest_bp.get()));
+}
+
 void MagiskInit::patch_fissiond(const char *tmp_path) noexcept {
     {
         LOGD("Patching fissiond\n");
@@ -322,6 +363,11 @@ void MagiskInit::patch_ro_root() noexcept {
     }
     if (p) patch_fissiond(tmp_dir.data());
 
+    // Patch vendor build.prop for zygote64_32
+    if (access(VENDOR_DIR "/" BUILD_PROP, F_OK) == 0) {
+        patch_build_prop(VENDOR_DIR);
+    }
+
     // Extract overlay archives
     extract_files(false);
 
